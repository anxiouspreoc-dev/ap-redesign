{% doc %}
  Renders a quantity input associated with a product

  @param {object} variant - A Shopify Variant object
  @param {object} product - A Shopify Product object
  @param {string} section_id - The id of the containing section
  @param {string} product_form_id - The id of the form to associate
  @param {string} variant_image_options - Array of variants for which to show variant images instead of the default styling
  @param {string} variant_picker_style - One of 'buttons', 'border', 'dropdown',
  @param {string} swatch_style - One of 'default' or 'none'


  @example
  {% render 'quantity-input',
    variant: product.selected_variant,
    product: product,
    product_form_id: 'unique-id',
    show_label: true,
  %}
{% enddoc %}

{%- unless product.has_only_default_variant -%}
  <variant-picker
    class="variant-picker"
    id="{{ product_form_id }}-variant-picker"
    data-options-length="{{ product.options.size }}"
    data-section="{{ section_id }}"
    {{ block.shopify_attributes }}
    tabindex="-1"
  >
    {% if variant == null %}
      <div data-error-id="{{ product_form_id }}" tabindex="-1" class="exception" id="{{ product_form_id }}-option-error" hidden>{{ 'products.product.select_options' | t }}</div>
    {% endif %}
    {%- for option in product.options_with_values -%}
      {%- liquid
        assign swatch_count = option.values | map: 'swatch' | compact | size
        assign computed_style = variant_picker_style
        if swatch_count > 0 and swatch_style != 'none'
          if variant_picker_style == 'buttons' or variant_picker_style == 'border'
            assign computed_style = 'swatch'
          endif
        endif
        for i in variant_image_options
          assign compare = i | strip
          if compare == option.name
            assign computed_style = 'images'
          endif
        endfor
      -%}

      {%- capture option_id -%}Option-{{ product_form_id }}-{{ forloop.index0 }}{%- endcapture -%}
      {%- if computed_style == 'dropdown' -%}
        <div class="variant-picker__input variant-picker__input--dropdown">
          <script src="{{ 'custom-select.js' | asset_url }}" defer="defer"></script>
          <span class="variant-picker__legend">
            <label for="{{ option_id }}" id="label_{{ option_id }}" class="caption">
              {{ option.name }}:
              <span data-selected-value>
                {% if variant %}{{- option.selected_value -}}{% endif %}
              </span>
            </label>
            {%- render 'variant-picker-modal', block: block,  option: option -%}
          </span>
          <custom-select class="variant-picker__select" data-focus-override="{{ option_id }}">
            <div class="select">
              <select
                id="{{ option_id }}"
                form="{{ product_form_id }}"
                name="options[{{ option.name | escape }}]"
                class="select__field caption"
              >
                {%- for value in option.values -%}
                  {%- liquid
                    assign option_disabled = true
                    if value.available
                      assign option_disabled = false
                    endif
                  -%}
                  {%- capture input_id -%}{{ product_form_id }}-{{ option.position }}-{{ forloop.index0 -}}{%- endcapture -%}
                  <option
                    id="{{ input_id }}"
                    data-option-value-id="{{ value.id }}"
                    value="{{ value | escape }}"
                    {% if variant and value.selected %}
                      selected="selected"
                    {% endif %}
                    {% if option_disabled %}
                      data-unavailable
                    {% endif %}
                  >
                    {% if option_disabled -%}
                      {{- 'products.product.value_unavailable' | t: option_value: value -}}
                    {%- else -%}
                      {{- value -}}
                    {%- endif -%}
                  </option>
                {%- endfor -%}
              </select>
              {%- render 'icon', icon: 'caret-down', class: 'icon--xs select__icon' -%}
            </div>
            <template>
              {%- for value in option.values -%}
                {%- capture input_id -%}{{ product_form_id }}-{{ option.position }}-{{ forloop.index0 -}}{%- endcapture -%}
                <div class="custom-select__option {% unless value.available %}custom-select__option--disabled{% endunless %} {% if variant and value.selected %}custom-select__option--highlighted{% endif %}" role="option" id="{{ input_id }}-option" {% if variant and value.selected %}aria-selected="true"{% endif %} data-value="{{ value | escape }}">
                  <div class="custom-select__option-wrapper">
                    <div class="custom-select__option-main caption">
                      {% if swatch_count > 0 and swatch_style != 'none' %}
                        {%- render 'swatch', swatch: value.swatch, fallback: value -%}
                      {% endif %}
                      <div>
                        {{- value -}}
                        {% unless value.available %}
                          <span class="custom-select__option-suffix">- {{ 'products.product.unavailable' | t }}</span>
                        {% endunless %}
                      </div>
                    </div>

                    {%- render 'icon', icon: 'check', class: 'icon--xs' -%}
                  </div>
                </div>
              {%- endfor -%}
            </template>
          </custom-select>
        </div>
      {%- elsif computed_style == 'buttons' or computed_style == 'border' -%}
        <fieldset class="variant-picker__input {% if computed_style =='buttons' %}variant-picker__input--button{% else %}variant-picker__input--border{% endif %} justify-inherit">
          <div class="variant-picker__legend justify-inherit">
            <legend class="caption">
              {{ option.name }}:
              <span data-selected-value>
                {% if variant %}{{- option.selected_value -}}{% endif %}
              </span>
            </legend>
            {%- render 'variant-picker-modal', block: block,  option: option -%}
          </div>
          <div class="variant-picker__options variant-picker__options--{{ computed_style }} justify-inherit">
            {%- for value in option.values -%}
              {%- liquid
                assign option_disabled = true
                if value.available
                  assign option_disabled = false
                endif
              -%}
              {%- capture input_id -%}{{ product_form_id }}-{{ option.position }}-{{ forloop.index0 -}}{%- endcapture -%}
              {%- capture input_name -%}{{ product_form_id }}-{{ option.name }}-{{ option.position }}{%- endcapture -%}
                <input
                  type="radio"
                  id="{{ input_id }}"
                  name="{{ input_name | escape }}"
                  value="{{ value | escape }}"
                  form="{{ product_form_id }}"
                  {% if variant and value.selected %}
                    checked
                  {% endif %}
                  class="variant-picker__radio {% if option_disabled %}disabled{% endif %}"
                  data-option-value-id="{{ value.id }}"
                >
                <label for="{{ input_id }}" class="variant-picker__label {% if computed_style =='buttons' %}variant-picker__label--button link-hover-underline{% else %}{% if variant and value.selected %}button button--primary{% else %}button button--secondary{% endif %} variant-picker__label--border{% endif %}{% if option_disabled %} disabled{% endif %}">
                  {%- if option_disabled -%}
                    <span><s>{{ value }}</s></span>
                  {%- else -%}
                  <span>{{ value }}</span>
                  {%- endif -%}
                  {%- if option_disabled -%}
                    <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
                  {%- endif -%}
                </label>
            {%- endfor -%}
          </div>
        </fieldset>
      {%- elsif computed_style == 'swatch' -%}
        <fieldset class="variant-picker__input variant-picker__input--swatch justify-inherit">
          <div class="variant-picker__legend justify-inherit">
            <legend class="caption">
              {{ option.name }}:
              <span data-selected-value>
                {% if variant %}{{- option.selected_value -}}{% endif %}
              </span>
            </legend>
            {%- render 'variant-picker-modal', block: block,  option: option -%}
          </div>

          {%- for value in option.values -%}
            {%- liquid
              assign option_disabled = true
              if value.available
                assign option_disabled = false
              endif
            -%}
            {%- capture input_id -%}{{ product_form_id }}-{{ option.position }}-{{ forloop.index0 -}}{%- endcapture -%}
            {%- capture input_name -%}{{ product_form_id }}-{{ option.name }}-{{ option.position }}{%- endcapture -%}
              <input
                type="radio"
                id="{{ input_id }}"
                name="{{ input_name | escape }}"
                value="{{ value | escape }}"
                form="{{ product_form_id }}"
                {% if variant and value.selected %}
                  checked
                {% endif %}
                class="variant-picker__radio {% if option_disabled %}disabled{% endif %}"
                data-option-value-id="{{ value.id }}"
              >
              <label
                for="{{ input_id }}"
                title="{{ value | escape }}"
                class="variant-picker__label variant-picker__label--swatch{% if option_disabled %} disabled{% endif %}"
              >
                <span class="visually-hidden">{{ value }}</span>
                {%- render 'swatch', swatch: value.swatch, fallback: value -%}
              </label>
          {%- endfor -%}
        </fieldset>
      {%- elsif computed_style == 'images' -%}
        <fieldset class="variant-picker__input variant-picker__input--images justify-inherit">
          <div class="variant-picker__legend justify-inherit">
            <legend class="caption">
              {{ option.name }}:
              <span data-selected-value>
                {% if variant %}{{- option.selected_value -}}{% endif %}
              </span>
            </legend>
            {%- render 'variant-picker-modal', block: block, option: option -%}
          </div>

          {%- for value in option.values -%}
            {%- liquid
              assign option_disabled = true
              if value.available
                assign option_disabled = false
              endif
            -%}
            {%- capture input_id -%}{{ product_form_id }}-{{ option.position }}-{{ forloop.index0 -}}{%- endcapture -%}
            {%- capture input_name -%}{{ product_form_id }}-{{ option.name }}-{{ option.position }}{%- endcapture -%}
              <input
                type="radio"
                id="{{ input_id }}"
                name="{{ input_name | escape }}"
                value="{{ value | escape }}"
                form="{{ product_form_id }}"
                {% if variant and value.selected %}
                  checked
                {% endif %}
                class="variant-picker__radio {% if option_disabled %}disabled{% endif %}"
                data-option-value-id="{{ value.id }}"
              >
              <label
                for="{{ input_id }}"
                title="{{ value | escape }}"
                class="variant-picker__image-label caption {% if option_disabled %} disabled{% endif %}"
              >
                {% if value.variant.featured_image %}
                  {% assign image = value.variant.featured_image %}
                {% else %}
                  {% assign image = product.featured_image %}
                {% endif %}
                {% comment %}Empty alt tag intentional, screen reader announcements too noisy otherwise.{% endcomment %}
                {{ image | image_url: width: 160 | image_tag:
                  class: 'variant-picker__image-label-image',
                  widths: '80, 160, 320',
                  height: image.height,
                  width: image.width,
                  alt: '',
                  sizes: '5rem'
                }}
                <span class="variant-picker__image-label-text">
                  {% if option_disabled %}
                    <s>{{ value }}</s>
                  {% else %}
                    {{ value }}
                  {% endif %}
                </span>
              </label>
          {%- endfor -%}
        </fieldset>
      {%- endif -%}
    {%- endfor -%}
    {%- if variant -%}
      <script type="application/json" data-selected-variant>
        {{ variant | json }}
      </script>
    {%- endif -%}
  </variant-picker>
{%- endunless -%}