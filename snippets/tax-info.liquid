{%- comment -%}
  Intended for use in a block similar to the text block.

  Accepts:
    has_discounts_enabled: {boolean} - whether discounts are enabled
{%- endcomment -%}

{%- if cart.duties_included and cart.taxes_included -%}
  {%- if shop.shipping_policy.body == blank -%}
    {%- if has_discounts_enabled -%}
      {{ 'cart.duties_and_taxes_included_shipping_at_checkout_without_policy_without_discounts' | t }}
    {%- else -%}
      {{ 'cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
    {%- endif -%}
  {%- else -%}
    {%- if has_discounts_enabled -%}
      {{
        'cart.duties_and_taxes_included_shipping_at_checkout_with_policy_without_discounts_html'
        | t: link: shop.shipping_policy.url
      }}
    {%- else -%}
      {{
        'cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
        | t: link: shop.shipping_policy.url
      }}
    {%- endif -%}
  {%- endif -%}
{%- elsif cart.duties_included == false and cart.taxes_included -%}
  {%- if shop.shipping_policy.body == blank -%}
    {%- if has_discounts_enabled -%}
      {{ 'cart.duties_and_taxes_included_shipping_at_checkout_without_policy_without_discounts' | t }}
    {%- else -%}
      {{ 'cart.taxes_included_shipping_at_checkout_without_policy' | t }}
    {%- endif -%}
  {%- else -%}
    {%- if has_discounts_enabled -%}
      {{
        'cart.duties_and_taxes_included_shipping_at_checkout_with_policy_without_discounts_html'
        | t: link: shop.shipping_policy.url
      }}
    {%- else -%}
      {{ 'cart.taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}
    {%- endif -%}
  {%- endif -%}
{%- elsif cart.duties_included and cart.taxes_included == false -%}
  {%- if shop.shipping_policy.body == blank -%}
    {%- if has_discounts_enabled -%}
      {{ 'cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy_without_discounts' | t }}
    {%- else -%}
      {{ 'cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
    {%- endif -%}
  {%- else -%}
    {%- if has_discounts_enabled -%}
      {{
        'cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_without_discounts_html'
        | t: link: shop.shipping_policy.url
      }}
    {%- else -%}
      {{
        'cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
        | t: link: shop.shipping_policy.url
      }}
    {%- endif -%}
  {%- endif -%}
{%- elsif cart.duties_included == false and cart.taxes_included == false -%}
  {%- if shop.shipping_policy.body == blank -%}
    {%- if has_discounts_enabled -%}
      {{ 'cart.taxes_at_checkout_shipping_at_checkout_without_policy_without_discounts' | t }}
    {%- else -%}
      {{ 'cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
    {%- endif -%}
  {%- else -%}
    {%- if has_discounts_enabled -%}
      {{
        'cart.taxes_at_checkout_shipping_at_checkout_with_policy_without_discounts_html'
        | t: link: shop.shipping_policy.url
      }}
    {%- else -%}
      {{ 'cart.taxes_at_checkout_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}
