{% doc %}
  Renders a swatch component.

  @param {string} swatch - Liquid Swatch object
  @param {string} [fallback] - Used to set a fallback color if the swatch object is not configured in the Shopify admin.

  @example
  {% render 'swatch',
    swatch: value.swatch
    shape: 'square'
  %}
{% enddoc %}

{%- liquid
  assign swatch_value = null
  assign swatch_fallback = fallback | split: ' ' | last
  if swatch.image
    assign image_url = swatch.image | image_url: width: 50
    assign swatch_value = 'url(' | append: image_url | append: ')'
    assign swatch_focal_point = swatch.image.presentation.focal_point
  elsif swatch.color
    assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
  endif

  if size == nil
    assign size = 'large'
  endif
-%}

<span
  {% if swatch_value %}
    class="swatch swatch--{{ settings.swatch_style }} swatch--{{ size }}"
    style="--swatch--background: {{ swatch_value }};{% if swatch_focal_point %} --swatch-focal-point: {{ swatch_focal_point }};{% endif %}'}"
  {% else %}
    class="swatch swatch--unavailable swatch--{{ settings.swatch_style }} swatch--{{ size }}" style="--swatch--background: {{ swatch_fallback }}"
  {% endif %}
></span>
