{%- assign product = section.settings.product | default: product -%}
{%- assign pairs = product.metafields.custom.best_paired_with.value -%}

<div class="pdp-pairs-with" {{ block.shopify_attributes }}>
  {%- if pairs != blank and pairs.size > 0 -%}
    <h2 class="pdp-pairs-with__heading">PAIRS WITH:</h2>

    <div class="pdp-pairs-with__scroll-wrapper">
      <ul class="pdp-pairs-with__list list-unstyled" role="list">
        {%- for paired_product in pairs -%}
          <li class="pdp-pairs-with__card">
            {%- if paired_product.featured_image != blank -%}
              <a href="{{ paired_product.url }}" class="pdp-pairs-with__image-link" tabindex="-1" aria-hidden="true">
                {{ paired_product.featured_image | image_url: width: 320 | image_tag:
                  class: 'pdp-pairs-with__image',
                  width: 130,
                  height: 130,
                  alt: paired_product.featured_image.alt | escape
                }}
              </a>
            {%- endif -%}

            <div class="pdp-pairs-with__content">
              <p class="pdp-pairs-with__title">
                <a href="{{ paired_product.url }}" class="pdp-pairs-with__title-link link-unstyled">
                  {{- paired_product.title -}}
                </a>
              </p>
              {%- render 'price', product: paired_product, font_style: 'caption' -%}
              <div class="pdp-pairs-with__cta">
                <a href="{{ paired_product.url }}" class="pdp-pairs-with__shop-now">
                  SHOP NOW
                </a>
                {%- assign pairs_section_id = section.id | append: '-pairs-' | append: forloop.index -%}
                {%- render 'quick-add',
                  product: paired_product,
                  section_id: pairs_section_id,
                  button_style: 'primary',
                  classes: 'pdp-pairs-with__quick-add'
                -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

    </div>

    {%- if pairs.size > 2 -%}
      <button class="pdp-pairs-with__show-more" type="button" aria-expanded="false">
        SHOW MORE
      </button>
    {%- endif -%}
  {%- endif -%}
</div>

<script>
(function() {
  var root = document.querySelector('.pdp-pairs-with');
  if (!root) return;

  var list = root.querySelector('.pdp-pairs-with__list');
  var showMoreBtn = root.querySelector('.pdp-pairs-with__show-more');

  // --- Show more (mobile) ---
  if (showMoreBtn) {
    showMoreBtn.addEventListener('click', function() {
      var expanded = list.classList.toggle('is-expanded');
      this.setAttribute('aria-expanded', String(expanded));
      this.textContent = expanded ? 'SHOW LESS' : 'SHOW MORE';
    });
  }

  // --- Drag to scroll (desktop) ---
  var isDragging = false;
  var startX = 0;
  var startScrollLeft = 0;
  var hasDragged = false;

  list.addEventListener('mousedown', function(e) {
    isDragging = true;
    hasDragged = false;
    startX = e.pageX;
    startScrollLeft = list.scrollLeft;
    list.style.cursor = 'grabbing';
    list.style.userSelect = 'none';
  });

  document.addEventListener('mouseup', function() {
    if (!isDragging) return;
    isDragging = false;
    list.style.cursor = '';
    list.style.userSelect = '';
  });

  document.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    var dx = e.pageX - startX;
    if (Math.abs(dx) > 4) hasDragged = true;
    list.scrollLeft = startScrollLeft - dx;
    updateArrows();
  });

  // Prevent link/button clicks when user was dragging
  list.addEventListener('click', function(e) {
    if (hasDragged) e.preventDefault();
  }, true);
})();
</script>

{% style %}
/* Override the theme's block gap (--space-m-l) with tighter spacing */
.pdp-pairs-with {
  --margin-block-start: var(--space-s);
  padding-block-start: 0;
}

/* Heading — matches accordion title: Bold 16px uppercase */
.pdp-pairs-with__heading {
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: 16px;
  text-transform: uppercase;
  color: #000000;
  margin: 0 0 12px 0;
  letter-spacing: 0;
}

/* Scroll wrapper — positions arrows relative to list */
.pdp-pairs-with__scroll-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0;
}


/* Mobile: vertical stack, show only first 2 by default */
.pdp-pairs-with__list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
  min-width: 0;
}

@media screen and (max-width: 749px) {
  .pdp-pairs-with__list:not(.is-expanded) .pdp-pairs-with__card:nth-child(n+3) {
    display: none;
  }
}

/* Desktop: horizontal scroll with drag cursor */
@media screen and (min-width: 750px) {
  .pdp-pairs-with__list {
    flex-direction: row;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
  }
  .pdp-pairs-with__list::-webkit-scrollbar {
    display: none;
  }
  .pdp-pairs-with__show-more {
    display: none !important;
  }
}

/* Card: image left, content right */
.pdp-pairs-with__card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 0;
  border-radius: 4px;
  overflow: hidden;
  background: #F4F4F4;
  width: 100%;
  border: none;
}

@media screen and (min-width: 750px) {
  .pdp-pairs-with__card {
    min-width: 340px;
    max-width: 445px;
    scroll-snap-align: start;
    flex-shrink: 0;
    width: auto;
  }
}

/* Product image */
.pdp-pairs-with__image-link {
  flex-shrink: 0;
  display: block;
  width: 130px;
}
.pdp-pairs-with__image {
  width: 130px;
  height: 100%;
  min-height: 130px;
  object-fit: cover;
  display: block;
}

/* Content area */
.pdp-pairs-with__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
  padding: 16px;
  justify-content: space-between;
}

/* Title */
.pdp-pairs-with__title {
  font-family: var(--font-body-family);
  font-size: 12px;
  font-weight: 700;
  margin: 0;
  line-height: 1.3;
  text-transform: uppercase;
}
.pdp-pairs-with__title-link {
  color: inherit;
  text-decoration: none;
}
.pdp-pairs-with__title-link:hover {
  text-decoration: underline;
}

/* Price — same font family as SHOP NOW, regular weight */
.pdp-pairs-with__content .price,
.pdp-pairs-with__content .price *,
.pdp-pairs-with__content .price-item,
.pdp-pairs-with__content .price-item--regular,
.pdp-pairs-with__content .price-item--sale,
.pdp-pairs-with__content .price__regular,
.pdp-pairs-with__content .price__sale {
  font-family: var(--font-body-family) !important;
  font-size: 13px !important;
  font-weight: 400 !important;
  margin: 0 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
}

/* CTA row: SHOP NOW left, cart button right */
.pdp-pairs-with__cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: auto;
  padding-top: 8px;
}
.pdp-pairs-with__shop-now {
  font-family: var(--font-body-family);
  color: #ff0064;
  text-transform: uppercase;
  font-weight: 400;
  font-size: 12px;
  text-decoration: none;
  letter-spacing: 0.02em;
  white-space: nowrap;
}
.pdp-pairs-with__shop-now:hover {
  text-decoration: underline;
}

/* Quick-add — circular green button */
.pdp-pairs-with__card .pdp-pairs-with__quick-add.button {
  background: #00ff00 !important;
  border-color: #00ff00 !important;
  color: #000000 !important;
  border-radius: 50% !important;
  width: 32px !important;
  height: 32px !important;
  min-width: 32px !important;
  min-height: 32px !important;
  max-height: 32px !important;
  padding: 0 !important;
  flex-shrink: 0;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  line-height: 1 !important;
  aspect-ratio: 1 / 1;
}
.pdp-pairs-with__card .pdp-pairs-with__quick-add.button:hover {
  background: #00dd00 !important;
  border-color: #00dd00 !important;
}
.pdp-pairs-with__card .pdp-pairs-with__quick-add.button .icon {
  width: 14px !important;
  height: 14px !important;
  flex-shrink: 0;
}

/* Show more button — mobile only */
.pdp-pairs-with__show-more {
  display: block;
  width: 100%;
  margin-top: 10px;
  padding: 10px 16px;
  background: transparent;
  border: 1px solid #000000;
  border-radius: 4px;
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #000000;
  cursor: pointer;
  text-align: center;
}
.pdp-pairs-with__show-more:hover {
  background: #000000;
  color: #ffffff;
}
{% endstyle %}

