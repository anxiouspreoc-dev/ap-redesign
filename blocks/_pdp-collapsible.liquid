{%- if block.settings.page != blank %}
  <div class="collapsible-items" {{ block.shopify_attributes }}>
    {%- render 'collapsible-content', heading: block.settings.heading, heading_size: block.settings.font_style, text: block.settings.page.content, block: block, open: block.settings.open_by_default -%}
  </div>
{%- elsif block.settings.text != blank -%}
  <div class="collapsible-items" {{ block.shopify_attributes }}>
    {%- render 'collapsible-content', heading: block.settings.heading, heading_size: block.settings.font_style, text: block.settings.text, block: block, open: block.settings.open_by_default -%}
  </div>
{%- endif -%}

{% schema %}
{
