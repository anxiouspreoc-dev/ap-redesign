
<div {% render 'color-scheme-attributes',  scoped_settings: section.settings %}>
  <div class="footer {% if section.settings.show_borders %}border--top{% endif %} padding--section"  style="{% render 'padding-override', settings: section.settings %}">
    <div class="container container--xl">
      <div class="footer__grid" style="{% if section.settings.vertical_spacing != 'default' %}--gap-vertical: {{ section.settings.vertical_spacing }};{% endif %}{% if section.settings.horizontal_spacing != 'default' %}--gap-horizontal: {{ section.settings.horizontal_spacing }};{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
           {%- when 'rich_text' -%}
              <div class="footer__item footer__item--rich-text footer__item--{{ block.settings.block_size }} {{ section.settings.horizontal_alignment }}" {{ block.shopify_attributes }}>
                <div class="rte">
                  {%- render 'generic-blocks', settings: block.settings, horizontal_alignment: section.settings.horizontal_alignment -%}
                </div>
                {%- if block.settings.show_social == true or shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                  <div class="footer__social-links justify-{{ section.settings.horizontal_alignment }}">
                    {%- if block.settings.show_social == true -%}
                      {% render 'social-icons', horizontal_alignment: section.settings.horizontal_alignment %}
                    {%- endif -%}
                    {%- if shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                      <div class="footer__follow-on-shop">
                        {{ shop | login_button: action: 'follow' }}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- when 'spacer' -%}
              <div class="footer__item footer__item--spacer" aria-hidden="true"></div>
            {%- when 'newsletter' -%}
              <div class="footer__item footer__item--newsletter footer__item--{{ block.settings.block_size }} {{ section.settings.horizontal_alignment }}" {{ block.shopify_attributes }}>
                {%- render 'newsletter',
                  form_id: 'ContactFooter',
                  settings: block.settings,
                  horizontal_alignment: section.settings.horizontal_alignment
                -%}
                {%- if block.settings.show_social == true or shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                  <div class="footer__social-links justify-{{ section.settings.horizontal_alignment }}">
                    {%- if block.settings.show_social == true -%}
                      {% render 'social-icons', horizontal_alignment: section.settings.horizontal_alignment %}
                    {%- endif -%}
                    {%- if shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                      <div class="footer__follow-on-shop">
                        {{ shop | login_button: action: 'follow' }}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- when 'link_list' -%}
              {%- if block.settings.menu != blank -%}
                {%- capture content -%}
                  <ul class="list-unstyled">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a href="{{ link.url }}" class="footer__menu-item link-hover-{{ section.settings.link_hover_style }} justify-{{ section.settings.horizontal_alignment }}">
                          <span>{{ link.title }}</span>
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {% endcapture %}
                {% capture heading_id %}footer-{{ block.id }}-heading{% endcapture %}
              <nav class="footer__item footer__item--{{ block.settings.block_size }} {{ section.settings.horizontal_alignment }} {% if block.settings.collapse %}footer__item--collapsible{% endif %}" {{ block.shopify_attributes }} {% if block.settings.heading != blank %}aria-labelledby="{{ heading_id }}"{% endif %}>
                  {% if block.settings.collapse %}
                    {%- render 'collapsible-content', heading: block.settings.heading, text: content, heading_size: section.settings.font_style, destroy: '(min-width:48em)', heading_id: heading_id -%}
                  {%- else -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 id="{{ heading_id }}" class="{{ section.settings.font_style }}">{{ block.settings.heading }}</h2>
                    {%- endif -%}
                    {{ content }}
                  {%- endif -%}
                </nav>
              {%- endif -%}
            {%- when 'image' -%}
              <div class="footer__item footer__item--{{ block.settings.block_size }} flex justify-{{ section.settings.horizontal_alignment }}" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {%- capture max_width -%}
                    {{ block.settings.max_width | times: 1.0 | divided_by: 16 }}rem
                  {%- endcapture -%}
                  {%- case block.settings.block_size -%}
                    {%- when 'small' -%}
                      {% capture sizes %}(min-width: 75em) calc(min(100vw, 87.5rem) / 6), min({{ max_width }}, 100vw){% endcapture %}
                    {%- when 'large' -%}
                      {% capture sizes %}(min-width: 75em) calc(min(100vw, 87.5rem) / 3), min({{ max_width }}, 100vw){% endcapture %}
                    {%- when 'full-width' -%}
                      {% capture sizes %}min(100vw, {{ max_width }}){% endcapture %}
                  {%- endcase -%}
                  {%- assign widths = '100, 200, 300, 400, 600, 800, 1200' -%}
                  {%- assign image_ratio = block.settings.image.aspect_ratio -%}
                  {%- if block.settings.image_ratio != 'default' -%}
                    {%- assign image_ratio = block.settings.image_ratio -%}
                  {%- endif -%}
                  {%- if block.settings.link != blank -%}
                    <a class="footer__image-link" href="{{ block.settings.link }}">
                    {%- if block.settings.link_label != blank -%}
                      <span class="visually-hidden">{{ block.settings.link_label }}.</span>
                    {%- endif -%}
                  {%- endif -%}
                  <div class="footer__image-wrapper image-ratio" style="--image-ratio: {{ image_ratio }};--image-max-width: {{ max_width }};">
                    {{
                      block.settings.image
                      | image_url: width: 2200
                      | image_tag:
                        sizes: sizes,
                        widths: widths
                    }}
                  </div>
                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                {%- else -%}
                  {%- if block.settings.link != blank -%}
                    <a class="footer__image-link" href="{{ block.settings.link }}">
                    {%- if block.settings.link_label != blank -%}
                      <span class="visually-hidden">{{ block.settings.link_label }}.</span>
                    {%- endif -%}
                  {%- endif -%}
                  {%- capture max_width -%}
                    {{ block.settings.max_width | times: 1.0 | divided_by: 16 }}rem
                  {%- endcapture -%}
                  <div class="footer__image-wrapper image-ratio" style="--image-ratio: 1;--image-max-width: {{ max_width }};background-color: rgba(var(--color-foreground), 0.2);">
                    {{- 'image' | placeholder_svg_tag -}}
                  </div>
                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- when 'logo' -%}
              <div class="footer__item footer__item--{{ block.settings.block_size }} rte {{ section.settings.horizontal_alignment }} flex flex-col items-{{ section.settings.horizontal_alignment }}" {{ block.shopify_attributes }}>
                {%- case block.settings.block_size -%}
                  {%- when 'small' -%}
                    {% assign sizes = '(min-width: 75em) calc(min(100vw, 87.5rem) / 6), 100vw' %}
                  {%- when 'large' -%}
                    {% assign sizes = '(min-width: 75em) calc(min(100vw, 87.5rem) / 3), 100vw' %}
                  {%- when 'full-width' -%}
                    {% assign sizes = 'min(100vw, 87.5rem)' %}
                {%- endcase -%}

                {% assign class = 'footer__logo' %}
                {% if block.settings.max_width == 'settings' %}
                  {% assign sizes = settings.logo_width | append: 'px' %}
                  {% assign class = 'footer__logo--settings' %}
                {% endif %}
                {%- assign widths = '100, 200, 300, 400, 600, 800, 1200, 1400, 1600, 1800, 2000, 2200' -%}

                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="footer__logo-link">
                  {%- if block.settings.link_label != blank -%}
                    <span class="visually-hidden">{{ block.settings.link_label }}.</span>
                  {%- endif -%}
                {%- endif -%}
                {%- if settings.logo != blank -%}
                  {%- assign logo = settings.logo -%}
                  {%- if block.settings.use_alt_logo and settings.logo_alt != blank -%}
                    {%- assign logo = settings.logo_alt -%}
                  {%- endif -%}
                  {%- assign logo_alt = logo.alt | default: shop.name | escape -%}
                  <div class="footer__logo-wrapper {{ section.settings.horizontal_alignment }}">
                    {{ logo | image_url: width: 1400 | image_tag:
                      class: class,
                      widths: widths,
                      height: logo.height,
                      width: logo.width,
                      alt: logo_alt,
                      sizes: sizes,
                      preload: true
                    }}
                  </div>
                {%- else -%}
                  <span class="heading h4">{{ shop.name }}</span>
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <div class="footer__logo-text {{ block.settings.font_style }} secondary">
                    {{- block.settings.text -}}
                  </div>
                {%- endif -%}
              </div>
            {%- when 'social_links' -%}
              <div
                class="footer__item footer__item--{{ block.settings.block_size }} {{ section.settings.horizontal_alignment }}"
                {%- if block.settings.layout == 'icons' -%}
                  style="--gap: var(--space-s);"
                {%- endif -%}
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.heading != blank -%}
                  <h2 class="{{ section.settings.font_style }}">{{ block.settings.heading }}</h2>
                {%- endif -%}
                <div class="footer__social-links justify-{{ section.settings.horizontal_alignment }}">
                  {%- case block.settings.layout -%}
                    {%- when 'text' -%}
                      {% render 'social-links', horizontal_alignment: section.settings.horizontal_alignment %}
                    {%- when 'icons' -%}
                      {% render 'social-icons', horizontal_alignment: section.settings.horizontal_alignment %}
                  {%- endcase -%}

                  {%- if shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                    <div class="footer__follow-on-shop">
                      {{ shop | login_button: action: 'follow' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- when 'ap_menu_group' -%}
              <div class="footer__item footer__item--ap-menu-group footer__item--full-width" {{ block.shopify_attributes }}>
                <div class="ap-menu-group">
                  {%- if block.settings.menu_1 != blank -%}
                    <nav class="ap-menu-group__column">
                      {%- if block.settings.heading_1 != blank -%}
                        <h2 class="{{ section.settings.font_style }}">{{ block.settings.heading_1 }}</h2>
                      {%- endif -%}
                      <ul class="list-unstyled">
                        {%- for link in block.settings.menu_1.links -%}
                          <li>
                            <a href="{{ link.url }}" class="footer__menu-item link-hover-{{ section.settings.link_hover_style }}">
                              <span>{{ link.title }}</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    </nav>
                  {%- endif -%}
                  {%- if block.settings.menu_2 != blank -%}
                    <nav class="ap-menu-group__column">
                      {%- if block.settings.heading_2 != blank -%}
                        <h2 class="{{ section.settings.font_style }}">{{ block.settings.heading_2 }}</h2>
                      {%- endif -%}
                      <ul class="list-unstyled">
                        {%- for link in block.settings.menu_2.links -%}
                          <li>
                            <a href="{{ link.url }}" class="footer__menu-item link-hover-{{ section.settings.link_hover_style }}">
                              <span>{{ link.title }}</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    </nav>
                  {%- endif -%}
                  {%- if block.settings.menu_3 != blank -%}
                    <nav class="ap-menu-group__column">
                      {%- if block.settings.heading_3 != blank -%}
                        <h2 class="{{ section.settings.font_style }}">{{ block.settings.heading_3 }}</h2>
                      {%- endif -%}
                      <ul class="list-unstyled">
                        {%- for link in block.settings.menu_3.links -%}
                          <li>
                            <a href="{{ link.url }}" class="footer__menu-item link-hover-{{ section.settings.link_hover_style }}">
                              <span>{{ link.title }}</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    </nav>
                  {%- endif -%}
                </div>
              </div>
            {%- when 'ap_custom_social' -%}
              <div class="footer__item footer__item--{{ block.settings.block_size }} footer__item--ap-social" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="{{ section.settings.font_style }}">{{ block.settings.heading }}</h2>
                {%- endif -%}
                <div class="ap-social-links ap-social-links--{{ block.settings.alignment }}">
                  {%- assign icon_size = block.settings.icon_size -%}
                  {%- if block.settings.icon_1 != blank -%}
                    <a href="{{ block.settings.url_1 }}" class="ap-social-link" {% if block.settings.label_1 != blank %}aria-label="{{ block.settings.label_1 }}"{% endif %}>
                      {{ block.settings.icon_1 | image_url: width: 120 | image_tag: width: icon_size, height: icon_size, alt: block.settings.label_1 }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.icon_2 != blank -%}
                    <a href="{{ block.settings.url_2 }}" class="ap-social-link" {% if block.settings.label_2 != blank %}aria-label="{{ block.settings.label_2 }}"{% endif %}>
                      {{ block.settings.icon_2 | image_url: width: 120 | image_tag: width: icon_size, height: icon_size, alt: block.settings.label_2 }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.icon_3 != blank -%}
                    <a href="{{ block.settings.url_3 }}" class="ap-social-link" {% if block.settings.label_3 != blank %}aria-label="{{ block.settings.label_3 }}"{% endif %}>
                      {{ block.settings.icon_3 | image_url: width: 120 | image_tag: width: icon_size, height: icon_size, alt: block.settings.label_3 }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.icon_4 != blank -%}
                    <a href="{{ block.settings.url_4 }}" class="ap-social-link" {% if block.settings.label_4 != blank %}aria-label="{{ block.settings.label_4 }}"{% endif %}>
                      {{ block.settings.icon_4 | image_url: width: 120 | image_tag: width: icon_size, height: icon_size, alt: block.settings.label_4 }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.icon_5 != blank -%}
                    <a href="{{ block.settings.url_5 }}" class="ap-social-link" {% if block.settings.label_5 != blank %}aria-label="{{ block.settings.label_5 }}"{% endif %}>
                      {{ block.settings.icon_5 | image_url: width: 120 | image_tag: width: icon_size, height: icon_size, alt: block.settings.label_5 }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.icon_6 != blank -%}
                    <a href="{{ block.settings.url_6 }}" class="ap-social-link" {% if block.settings.label_6 != blank %}aria-label="{{ block.settings.label_6 }}"{% endif %}>
                      {{ block.settings.icon_6 | image_url: width: 120 | image_tag: width: icon_size, height: icon_size, alt: block.settings.label_6 }}
                    </a>
                  {%- endif -%}
                </div>
              </div>
          {%- endcase %}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% style %}
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');
/* Footer font */
#shopify-section-footer,
#shopify-section-footer * {
  font-family: 'Instrument Sans', sans-serif;
}
/* Footer background */
#shopify-section-footer .footer {
  background-color: #F5EFF8;
}
/* AP logo max-width cap */
#shopify-section-footer .footer__logo,
#shopify-section-footer .footer__logo-wrapper {
  inline-size: 136px !important;
  max-inline-size: 136px !important;
}
/* Social icons spacing */
#shopify-section-footer .footer__social-links {
  gap: var(--space-xs);
  margin-block-start: var(--space-s);
}
/* Newsletter subscribe button — match site primary purple via CSS vars */
#shopify-section-footer {
  --color-primary-button: 93, 0, 110;
  --color-primary-button-border: 93, 0, 110;
  --color-primary-button-label: 255, 255, 255;
  --color-primary-button-hover: 74, 0, 88;
}
/* Button text uppercase */
#shopify-section-footer .button {
  text-transform: uppercase;
}
/* Nav link colour */
#shopify-section-footer .footer__menu-item {
  color: inherit;
  opacity: 0.75;
}
#shopify-section-footer .footer__menu-item:hover {
  opacity: 1;
}
/* Menu group: 3-column grid */
#shopify-section-footer .ap-menu-group {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-l);
}
@media (max-width: 47.99em) {
  #shopify-section-footer .ap-menu-group {
    grid-template-columns: 1fr;
  }
}
/* Custom social icon links */
#shopify-section-footer .ap-social-links {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: var(--space-s);
  align-items: center;
}
#shopify-section-footer .ap-social-links--left   { justify-content: flex-start; }
#shopify-section-footer .ap-social-links--center { justify-content: center; }
#shopify-section-footer .ap-social-links--right  { justify-content: flex-end; }
#shopify-section-footer .ap-social-link {
  display: flex;
  flex-shrink: 0;
}
#shopify-section-footer .ap-social-link img {
  display: block;
  object-fit: contain;
}
{% endstyle %}

