{%- liquid
  assign fetch_priority = 'auto'
  assign loading = 'eager'
  if section.index == 1 and section.location != 'footer'
    assign fetch_priority = 'high'
    assign loading = 'eager'
  endif
-%}

{% style %}
/* Body text: black (overrides pink from color scheme) */
#shopify-section-{{ section.id }} .rte p,
#shopify-section-{{ section.id }} .rte li,
#shopify-section-{{ section.id }} .rte {
  color: #000000;
}
/* Heading stays pink — inherited from color scheme */

/* Button: #5D006E background, white text, uppercase */
#shopify-section-{{ section.id }} {
  --color-primary-button: 93, 0, 110;
  --color-primary-button-border: 93, 0, 110;
  --color-primary-button-label: 255, 255, 255;
  --color-primary-button-hover: 74, 0, 88;
}
#shopify-section-{{ section.id }} .button {
  text-transform: uppercase;
}

/* ---- Image stacking: compact overlapping card effect ---- */
/* Remove full-viewport sticky scroll height */
#shopify-section-{{ section.id }} .stacked-images-with-text__list-item {
  position: relative !important;
  inset-block-start: auto !important;
  min-block-size: 0 !important;
}

/* Pull 2nd image up to create overlap */
#shopify-section-{{ section.id }} .stacked-images-with-text__list-item + .stacked-images-with-text__list-item {
  margin-block-start: -120px;
  transform: translateX(40px);
  z-index: 1;
}

/* First image sits on top */
#shopify-section-{{ section.id }} .stacked-images-with-text__list-item:first-child {
  position: relative;
  z-index: 2;
}

/* Desktop: reduce text-wrapper sticky height to natural content height */
@media (min-width: 48em) and (orientation: landscape) {
  #shopify-section-{{ section.id }} .stacked-images-with-text__text-wrapper {
    min-block-size: 0 !important;
    align-self: center;
    padding-block: var(--space-2xl);
  }
}
{% endstyle %}

<div {% render 'color-scheme-attributes',  scoped_settings: section.settings, borders: true %}>
  <div class="container container--xl">
    <stacked-images-with-text class="stacked-images-with-text">
      <div class="stacked-images-with-text__text-wrapper {{ section.settings.horizontal_alignment }}">
        <div class="rte rte--loose justify-{{ section.settings.horizontal_alignment }}">
          {% content_for 'blocks' %}
        </div>
      </div>
      {%- if section.blocks.size > 0 -%}
        <div class="stacked-images-with-text__list-wrapper">
          {% content_for "block", type: "_stacked-images", id: "stacked-images" %}
        </div>
      {%- endif -%}
    </stacked-images-with-text>
  </div>
</div>

{% schema %}
{
  "name": "t:stacked-images-with-text",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "horizontal_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:left"
        },
        {
          "value": "center",
          "label": "t:center"
        },
        {
          "value": "right",
          "label": "t:right"
        }
      ],
      "default": "center",
      "label": "t:horizontal-alignment"
    },
    {
      "type": "header",
      "content": "t:colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:color-scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "enable_color_scheme_transition",
      "label": "t:use-color-scheme-transition",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_transition",
      "label": "t:transition-color-scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:borders"
    },
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "t:show-top-border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "t:show-bottom-border",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "t:stacked-images-with-text",
      "settings": {
        "horizontal_alignment": "center"
      },
      "blocks": [
        {
          "type": "heading-group",
          "blocks": [
            {
              "type": "_subheading"
            },
            {
              "type": "_heading",
              "settings": {
                "heading": "Stacked images with text"
              }
            }
          ]
        },
        {
          "type": "text"
        },
        {
          "type": "button-group",
          "blocks": [
            {
              "type": "_button"
            }
          ]
        },
        {
          "type": "_stacked-images",
          "id": "stacked-images",
          "static": true,
          "blocks": [
            {
              "type": "_stacked-image",
              "settings": {
                "image_ratio": "1",
                "max_width": 90
              }
            },
            {
              "type": "_stacked-image",
              "settings": {
                "image_ratio": "2 / 3",
                "max_width": 80
              }
            },
            {
              "type": "_stacked-image",
              "settings": {
                "image_ratio": "3 / 2",
                "max_width": 100
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
