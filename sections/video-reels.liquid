{%- liquid
  assign columns_desktop = section.settings.columns_desktop | times: 1
  assign columns_mobile = section.settings.columns_mobile | times: 1
-%}

<script src="{{ 'video-reels.js' | asset_url }}" type="module"></script>

<div {% render 'color-scheme-attributes',  scoped_settings: section.settings, borders: true %}>
  <div class="media-grid padding--section gap--section overflow-hidden" style="{% if section.settings.grid_gap_vertical != 'default' %}--gap-vertical: {{ section.settings.grid_gap_vertical }};{% endif %}{% if section.settings.grid_gap_horizontal != 'default' %}--gap-horizontal: {{ section.settings.grid_gap_horizontal }};{% endif %}; {% render 'padding-override', settings: section.settings %}">
    {% content_for "block", type: "_section-header", id: "section-header" %}
    {%- capture inner_content -%}
      <ul class="slider-component__grid list-unstyled">
        {% content_for 'blocks' %}
      </ul>
    {%- endcapture -%}

    {% capture content %}
      {% render 'slider-component-inner',
        id: section.id,
        container_type: section.settings.container_type,
        column_behavior: section.settings.column_behavior
        columns_desktop: columns_desktop,
        columns_mobile: 1,
        content: inner_content,
        text: false
      %}
    {% endcapture %}
    <video-reels
      data-reel-autoplay="{{ section.settings.enable_autoplay }}"
      data-label="{{ section.id }}-Section-Heading"
      class="video-reels slider-component"
      data-desktop-columns="{{ columns_desktop }}"
      data-hide-inactive-products="{{ section.settings.hide_inactive_products }}"
    >
      {{ content }}
      <div class="slideshow__pagination slider-component__pagination slider-component__pagination--{{ section.settings.arrow_position }}  slider-component__pagination--counter-{{ section.settings.counter_style }}">
        {%- render 'pagination-slideshow', button_style: section.settings.button_style, arrow_style: section.settings.arrow_position, counter_style: section.settings.counter_style -%}
      </div>
    </video-reels>

    <div class="section-button-group container container--xl">
      {% content_for "block", type: "button-group", id: "button-group" %}
    </div>
  </div>
</div>

